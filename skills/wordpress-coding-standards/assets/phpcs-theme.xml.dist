<?xml version="1.0"?>
<ruleset name="WordPress Theme Coding Standards">
    <description>
        WPCS ruleset tuned for theme development. Includes the standard WordPress
        rules plus theme-specific checks (escaping in templates, no enqueue side effects,
        proper template tags). Customize text_domain, prefixes, and versions before
        committing.
    </description>

    <!-- ============================== Files & arguments ============================ -->

    <file>.</file>

    <exclude-pattern>/vendor/*</exclude-pattern>
    <exclude-pattern>/node_modules/*</exclude-pattern>
    <exclude-pattern>/build/*</exclude-pattern>
    <exclude-pattern>/dist/*</exclude-pattern>
    <exclude-pattern>/tests/fixtures/*</exclude-pattern>
    <exclude-pattern>*.min.*</exclude-pattern>
    <!-- Compiled/exported template parts. -->
    <exclude-pattern>*-asset.php</exclude-pattern>

    <arg name="extensions" value="php"/>
    <arg value="psv"/>
    <arg name="colors"/>
    <arg name="parallel" value="8"/>
    <arg name="cache" value=".phpcs.cache"/>

    <!-- ============================== Standards ===================================== -->

    <!-- WordPress core + extra + docs. -->
    <rule ref="WordPress">
        <!-- Themes often use template files that won't follow class-foo.php naming. -->
        <!-- The WordPress.Files.FileName sniff is generally fine for themes; only exclude if needed. -->
    </rule>

    <!-- Theme-specific checks: forbids inline JS/CSS, enforces enqueue, etc. -->
    <rule ref="WordPress-Theme"/>

    <!--
        Some theme-specific rules are aggressive and can be relaxed for child themes
        or specialized themes. Uncomment to relax:
    -->

    <!-- Allow inline CSS in template files (sometimes unavoidable for dynamic colors): -->
    <!-- <exclude name="WordPress.WP.EnqueuedResources.NonEnqueuedStylesheet"/> -->

    <!-- ============================== Project-specific configuration ================ -->

    <rule ref="WordPress.WP.I18n">
        <properties>
            <property name="text_domain" type="array">
                <element value="your-theme-slug"/>
            </property>
        </properties>
    </rule>

    <!--
        Theme prefixes. Themes prefix function names, but template files often
        use short names (header.php, footer.php), so we focus prefixing on functions
        in functions.php and lib/ directories.
    -->
    <rule ref="WordPress.NamingConventions.PrefixAllGlobals">
        <properties>
            <property name="prefixes" type="array">
                <element value="your_theme"/>
                <element value="Your_Theme"/>
                <element value="YOUR_THEME"/>
            </property>
        </properties>
    </rule>

    <!-- ============================== Version compatibility ========================= -->

    <config name="minimum_wp_version" value="6.2"/>

    <config name="testVersion" value="7.4-"/>
    <rule ref="PHPCompatibilityWP"/>

    <!-- ============================== Theme-specific overrides ====================== -->

    <!--
        Template files (header.php, footer.php, single.php, page.php, etc.) are
        included files, not standalone scripts. PHPCS may flag function names not
        being prefixed, but template tags like 'the_title' are intentional.
        We don't need to suppress here — WPCS understands template hierarchy.
    -->

</ruleset>